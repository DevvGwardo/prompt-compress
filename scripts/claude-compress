#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Compress prompts before sending them to Claude Code.

Usage:
  claude-compress [wrapper-options] -- [claude-args...]
  claude-compress [wrapper-options] [claude-args...]

Prompt sources (priority):
  1) --prompt "..."
  2) stdin (if piped)
  3) interactive first prompt (plain launch, optional)

Wrapper options:
  --prompt TEXT              Prompt text to compress
  --aggressiveness FLOAT     Compression aggressiveness (default: 0.5)
  --target-model MODEL       Token counter target model (default: gpt-4)
  --onnx                     Use ONNX scorer
  --model-dir PATH           ONNX model directory
  --stats                    Print compression stats to stderr
  -h, --help                 Show help

Environment defaults:
  PROMPT_COMPRESS_AGGRESSIVENESS
  PROMPT_COMPRESS_TARGET_MODEL
  PROMPT_COMPRESS_USE_ONNX      (1/true/yes to enable)
  PROMPT_COMPRESS_MODEL          (used by compress --model-dir and ONNX auto-discovery)
  PROMPT_COMPRESS_BIN            (path to prompt-compress binary)
  PROMPT_COMPRESS_CLAUDE_BIN     (path to claude binary, optional)
  PROMPT_COMPRESS_INTERACTIVE_FIRST_PROMPT
                                (1/true/yes to prompt for an initial
                                 message when launched with no args)
EOF
}

to_bool() {
  case "${1:-}" in
    1|true|TRUE|yes|YES|on|ON) return 0 ;;
    *) return 1 ;;
  esac
}

AGGRESSIVENESS="${PROMPT_COMPRESS_AGGRESSIVENESS:-0.5}"
TARGET_MODEL="${PROMPT_COMPRESS_TARGET_MODEL:-gpt-4}"
USE_ONNX=0
MODEL_DIR="${PROMPT_COMPRESS_MODEL:-}"
SHOW_STATS=0
PROMPT=""
INTERACTIVE_FIRST_PROMPT=0

if to_bool "${PROMPT_COMPRESS_USE_ONNX:-0}"; then
  USE_ONNX=1
fi

if to_bool "${PROMPT_COMPRESS_INTERACTIVE_FIRST_PROMPT:-1}"; then
  INTERACTIVE_FIRST_PROMPT=1
fi

while [[ $# -gt 0 ]]; do
  case "$1" in
    --prompt)
      [[ $# -ge 2 ]] || { echo "error: --prompt requires a value" >&2; exit 2; }
      PROMPT="$2"
      shift 2
      ;;
    --aggressiveness)
      [[ $# -ge 2 ]] || { echo "error: --aggressiveness requires a value" >&2; exit 2; }
      AGGRESSIVENESS="$2"
      shift 2
      ;;
    --target-model)
      [[ $# -ge 2 ]] || { echo "error: --target-model requires a value" >&2; exit 2; }
      TARGET_MODEL="$2"
      shift 2
      ;;
    --onnx)
      USE_ONNX=1
      shift
      ;;
    --model-dir)
      [[ $# -ge 2 ]] || { echo "error: --model-dir requires a value" >&2; exit 2; }
      MODEL_DIR="$2"
      shift 2
      ;;
    --stats)
      SHOW_STATS=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      break
      ;;
    *)
      break
      ;;
  esac
done

CLAUDE_ARGS=("$@")

resolve_claude_cmd() {
  if [[ -n "${PROMPT_COMPRESS_CLAUDE_BIN:-}" ]]; then
    if [[ -x "${PROMPT_COMPRESS_CLAUDE_BIN}" ]]; then
      echo "${PROMPT_COMPRESS_CLAUDE_BIN}"
      return 0
    fi
    echo "error: PROMPT_COMPRESS_CLAUDE_BIN is set but not executable: ${PROMPT_COMPRESS_CLAUDE_BIN}" >&2
    exit 1
  fi

  local candidate
  candidate="$(command -v claude || true)"
  if [[ -n "$candidate" ]]; then
    echo "$candidate"
    return 0
  fi

  if [[ -x /opt/homebrew/bin/claude ]]; then
    echo /opt/homebrew/bin/claude
    return 0
  fi

  echo "error: could not locate claude binary in PATH" >&2
  exit 1
}

resolve_compress_cmd() {
  local script_dir
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

  if [[ -n "${PROMPT_COMPRESS_BIN:-}" ]]; then
    if [[ -x "${PROMPT_COMPRESS_BIN}" ]]; then
      echo "${PROMPT_COMPRESS_BIN}"
      return 0
    fi
    echo "error: PROMPT_COMPRESS_BIN is set but not executable: ${PROMPT_COMPRESS_BIN}" >&2
    exit 1
  fi

  if [[ -x "./target/release/compress" ]]; then
    echo "./target/release/compress"
    return 0
  fi

  if [[ -x "${script_dir}/../target/release/compress" ]]; then
    echo "${script_dir}/../target/release/compress"
    return 0
  fi

  if command -v compress >/dev/null 2>&1; then
    local candidate
    candidate="$(command -v compress)"
    if "$candidate" --help 2>&1 | grep -q "LLM prompt compression tool"; then
      echo "$candidate"
      return 0
    fi
  fi

  return 1
}

CLAUDE_BIN="$(resolve_claude_cmd)"

# Resolve prompt from stdin when available.
if [[ -z "$PROMPT" ]]; then
  if [[ ! -t 0 ]]; then
    PROMPT="$(cat)"
  fi
fi

# Optional interactive initial prompt for plain launches.
if [[ -z "$PROMPT" && ${#CLAUDE_ARGS[@]} -eq 0 && $INTERACTIVE_FIRST_PROMPT -eq 1 && -t 0 ]]; then
  printf "claude-compress initial prompt (blank to skip): " >&2
  IFS= read -r PROMPT || true
fi

# If no prompt, run claude unchanged.
if [[ -z "${PROMPT//[[:space:]]/}" ]]; then
  exec "$CLAUDE_BIN" "${CLAUDE_ARGS[@]}"
fi

COMPRESS_BIN="$(resolve_compress_cmd || true)"
if [[ -z "$COMPRESS_BIN" ]]; then
  echo "error: compress binary not found. Build first with: cargo build --release" >&2
  exit 1
fi

compress_cmd=(
  "$COMPRESS_BIN"
  -i "$PROMPT"
  -a "$AGGRESSIVENESS"
  -m "$TARGET_MODEL"
  --format text
)

if (( USE_ONNX )); then
  compress_cmd+=(--onnx)
fi

if [[ -n "$MODEL_DIR" ]]; then
  compress_cmd+=(--model-dir "$MODEL_DIR")
fi

if (( SHOW_STATS )); then
  compress_cmd+=(--stats)
fi

COMPRESSED_PROMPT="$("${compress_cmd[@]}")"

if [[ -z "${COMPRESSED_PROMPT//[[:space:]]/}" ]]; then
  echo "error: compressed prompt is empty; aborting" >&2
  exit 1
fi

# Claude Code uses -p for non-interactive print mode.
# Pass compressed prompt as the positional argument.
exec "$CLAUDE_BIN" -p "${CLAUDE_ARGS[@]}" "$COMPRESSED_PROMPT"
