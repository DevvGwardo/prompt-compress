#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

cat >&2 <<'EOF'
[prompt-compress] scripts/codex-proxy is deprecated for native interactive Codex.
[prompt-compress] Current Codex CLI builds bypass the HTTP proxy path for real turns.
[prompt-compress] Starting the working codex-chat-compress wrapper instead.
EOF

exec "${SCRIPT_DIR}/codex-chat-compress" "$@"
